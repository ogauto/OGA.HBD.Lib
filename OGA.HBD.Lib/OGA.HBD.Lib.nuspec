<?xml version="1.0" encoding="utf-8"?>
<package >
  <metadata>
    <id>OGA.HBD.Lib</id>
    <title>OGA Host Bootstrap Document Libraries</title>
    <version>1.0.1</version>
    <authors>Lee White</authors>
    <owners>Lee White</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>OGA Host Bootstrap Document Library</description>
    <releaseNotes>(Please write the package release notes in "OGA.HBD.Lib-RELEASE_NOTES.txt".)</releaseNotes>
    <copyright>$copyright$</copyright>
    <repository type="git" url="https://github.com/ogauto/OGA.HBD.Lib" />
    <license type="expression">MIT</license>
    <readme>docs\README.md</readme>

    <dependencies>
      <group targetFramework="net5.0">
        <dependency id="Microsoft.IdentityModel.JsonWebTokens" version="8.13.1" exclude="Build,Analyzers" />
